# ============================================
# DragBuilder 数据库环境变量配置示例
# ============================================
# 将此文件复制为 .env 并根据实际情况修改配置
# 用于后端项目（drag-builder-server）
# ============================================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# 数据库用户名
DB_USERNAME=onism

# 数据库密码
DB_PASSWORD=123456

# 数据库名称
DB_DATABASE=dragbuilder

# 数据库连接池配置（可选）
DB_POOL_MIN=2
DB_POOL_MAX=10

# 是否启用 SSL 连接（生产环境建议启用）
DB_SSL=false

# 是否启用同步（开发环境可以启用，生产环境必须禁用）
DB_SYNCHRONIZE=true

# 是否启用日志（开发环境可以启用）
DB_LOGGING=true

# ============================================
# 注意事项
# ============================================
# 1. 生产环境请使用强密码
# 2. 生产环境必须禁用 DB_SYNCHRONIZE
# 3. 生产环境建议启用 DB_SSL
# 4. 不要将 .env 文件提交到版本控制系统
# ============================================
